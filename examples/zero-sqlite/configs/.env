# SQLite Example Template
# ====================================
# Copy this to .dev.env and configure for your environment

# Application Settings
APP_ENV=dev
APP_NAME=sqlite-demo
LOG_LEVEL=debug
HTTP_PORT=9081

# Database Configuration
# Uncomment and configure the following to use SQLite:
DB_DIALECT=sqlite
SQLITE_PATH=./data/app.db
SQLITE_CREATE=true
SQLITE_WRITE=true
SQLITE_THREADING=multi-thread